{
    "env": {
        "commonjs": true,
        "es6": true,
        "node": true
    },
    "extends": "google",
    "globals": {
        "Atomics": "readonly",
        "SharedArrayBuffer": "readonly"
    },
    "parserOptions": {
        "ecmaVersion": 2018
    },
    "rules": {
        "new-cap": 0,
        "camelcase": 0,
        "indent": ["error", 2],
        "max-len": ["error", 100],
        "require-jsdoc": 0
    }
}